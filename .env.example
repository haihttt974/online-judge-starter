JUDGE0_POSTGRES_PASSWORD=replace-with-a-strong-password
JUDGE0_REDIS_PASSWORD=replace-with-a-strong-password
# Pin this in production after verifying the language IDs exposed by GET /languages.
JUDGE0_IMAGE=judge0/judge0:latest

# Optional backend overrides
# JUDGE0_CPU_TIME_LIMIT=2
# JUDGE0_WALL_TIME_LIMIT=5
# JUDGE0_MEMORY_LIMIT=128000
# JUDGE0_MAX_MEMORY_LIMIT=524288
# JUDGE0_MAX_SOURCE_CODE_SIZE=65536
# JUDGE0_MAX_TESTCASES=500
# Per-file testcase limits; values above 2097152 are capped at 2 MB.
# JUDGE0_MAX_STDIN_SIZE=2097152
# JUDGE0_MAX_EXPECTED_OUTPUT_SIZE=2097152
# JUDGE0_REQUEST_TIMEOUT_MS=60000
# JUDGE0_COMPILE_ONCE=true
# JUDGE0_COMPILE_ONCE_LANGUAGES=c,cpp,pascal,csharp,python
# JUDGE0_COMPILE_ONCE_MAX_CPU_SECONDS=300
# JUDGE0_COMPILE_ONCE_MAX_WALL_SECONDS=600
# JUDGE0_TESTCASE_CONCURRENCY=4
# JUDGE0_CONNECT_RETRY_COUNT=3
# JUDGE0_CONNECT_RETRY_DELAY_MS=1000
# JUDGE0_WAIT_ON_START=true
# JUDGE0_URLS=http://judge0-server:2358,http://localhost:2358
# JUDGE0_USE_BATCH=true
# JUDGE0_BATCH_SIZE=20
# JUDGE0_WORKER_COUNT=8
# JUDGE0_COMPILATION_RETRY_COUNT=2
# JUDGE_MAX_RESPONSE_FIELD_BYTES=16384
# JUDGE0_POLL_INTERVAL_MS=100
# Set true when the host only provides cgroup v2, such as Docker Desktop.
# JUDGE0_PER_PROCESS_LIMITS=false
# JUDGE0_LANGUAGE_ID_CPP=54
